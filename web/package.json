		"@types/node": "25.6.0",
		"svelte": "5.55.4",
		"svelte-check": "4.4.6",
		"typescript": "6.0.3",
		"vite": "8.0.9"
	},
	"dependencies": {
		"@neondatabase/serverless": "1.1.0"
	}
