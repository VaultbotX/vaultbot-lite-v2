# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Serialized OAuth token: accessToken|refreshToken|tokenType|expiryUnix
# See README.md for token generation instructions
SPOTIFY_TOKEN=
SPOTIFY_PLAYLIST_ID=
GENRE_SPOTIFY_PLAYLIST_ID=
HIGH_SCORES_SPOTIFY_PLAYLIST_ID=

# Database (Neon PostgreSQL)
# In devcontainer: populated automatically by .devcontainer/scripts/neon-branch-setup.sh
# In production: stored as GitHub Actions secrets
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=neondb

# Neon branch management (devcontainer / local tooling only)
NEON_API_KEY=
NEON_PROJECT_ID=
